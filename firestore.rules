rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tenants collection - only admins of a tenant should manage this in a real app.
    match /tenants/{tenantId} {
      allow read: if request.auth != null;
      allow write: if false; // managed via console / backend
    }

    // Users: each document id is the auth uid.
    match /user/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Bookings: multi-tenant and per-patient access control.
    match /bookings/{bookingId} {
      allow read: if isTenantMatch() && (isAdminForTenant() || isOwnBooking());
      allow write: if isTenantMatch() && isAdminForTenant();

      function isTenantMatch() {
        return request.resource.data.tenant_id == resource.data.tenant_id;
      }

      function isOwnBooking() {
        return request.auth != null && resource.data.patient_id == request.auth.uid;
      }

      function isAdminForTenant() {
        return request.auth != null &&
          exists(/databases/$(database)/documents/user/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/user/$(request.auth.uid)).data.role == 'admin';
      }
    }
  }
}

