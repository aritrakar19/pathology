rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Tenants collection - only admins of a tenant should manage this in a real app.
    match /tenants/{tenantId} {
      allow read: if request.auth != null;
      allow write: if false; // managed via console / backend
    }

    // Users: each document id is the auth uid.
    // - Any authenticated user can read their own doc (getUserRole).
    // - Any authenticated user can create/update their own doc (saveUserWithRole).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      allow delete: if false;
    }

    // Bookings: multi-tenant and per-patient access control.
    match /bookings/{bookingId} {
      allow read: if request.auth != null && (isAdminForTenant() || isOwnBooking());
      allow create: if request.auth != null;
      allow update: if request.auth != null && isAdminForTenant();
      allow delete: if false;

      function isOwnBooking() {
        return resource.data.userId == request.auth.uid;
      }

      function isAdminForTenant() {
        return exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
    }

    match /medicines/{medicineId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // Allow checkout to reduce stock
    }

    match /doctors/{doctorId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Appointments: created by users, updated by admin/doctor
    match /appointments/{appointmentId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
      allow delete: if false;
    }

    // Doctor availability and slot management
    match /doctor_availability/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /master_tests/{testId} {
      allow read: if true; // Public or authenticated depending on app needs, but read-only for public
      allow write: if request.auth != null && isAdminForTenant(); // Central admin in a real app
    }

    match /tenant_tests/{tenantTestId} {
      allow read: if true;
      allow write: if request.auth != null && isAdminForTenant();
    }

    match /packages/{packageId} {
      allow read: if true;
      allow write: if request.auth != null && isAdminForTenant();
    }
  }
}

